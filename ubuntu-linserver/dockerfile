ARG TAG=24.04
FROM ubuntu:${TAG}

LABEL maintainer="Luiz Claubert <luizclaubertss@gmail.com>"
LABEL version="v0.2"

# Evita prompts interativos
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=America/Sao_Paulo

# Atualiza pacotes e instala o necessário
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        sudo \
        openssh-server \
        ldap-utils \
        slapd \
        vim \
        nano \
        curl \
        wget \
        net-tools \
        iproute2 \
        language-pack-pt \
        language-pack-pt-base && \
    rm -rf /var/lib/apt/lists/* && \
    apt-get clean

# Suporte a português
RUN update-locale LANG=pt_BR.UTF-8

# ==================== CONFIGURAÇÃO SSH ====================
RUN mkdir /var/run/sshd && \
    # Cria usuário 'aluno' e acesso sudo
    useradd -m -s /bin/bash aluno && \
    echo "aluno:rnpesr" | chpasswd && \
    usermod -aG sudo aluno && \

    # Senha do root
    echo "root:rnpesr" | chpasswd && \

    # Permite login com senha via SSH
    sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    sed -i 's/PasswordAuthentication no/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    sed -i 's/#PermitRootLogin yes/PermitRootLogin yes/' /etc/ssh/sshd_config

# ==================== CONFIGURAÇÃO LDAP (OpenLDAP) ====================
# Configuração non-interactive do slapd
RUN echo "slapd slapd/internal/generated_adminpw password admin" | debconf-set-selections && \
    echo "slapd slapd/password1 password admin" | debconf-set-selections && \
    echo "slapd slapd/password2 password admin" | debconf-set-selections && \
    echo "slapd slapd/domain string example.local" | debconf-set-selections && \
    echo "slapd shared/organization string Example" | debconf-set-selections && \
    dpkg-reconfigure -f noninteractive slapd

# Cria usuário Charlie (senha: passwd)
RUN echo 'dn: uid=charlie,ou=people,dc=example,dc=local
objectClass: inetOrgPerson
objectClass: posixAccount
objectClass: shadowAccount
uid: charlie
sn: Charlie
givenName: Charlie
cn: Charlie
displayName: Charlie
uidNumber: 1001
gidNumber: 1001
userPassword: {SSHA}
